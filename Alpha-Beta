def alphabeta(depth,nodei,maximizing,values,alpha,beta):
    if depth==3:
        return values[nodei]
    if maximizing:
        best=float('-inf')
        for i in range(2):
            value=alphabeta(depth+1,nodei*2+i,False,values,alpha,beta)
            best=max(value,best)
            alpha=max(alpha,best)
            if alpha>=beta:
                break
        return best
    else:
        best=float('inf')
        for i in range(2):
            value=alphabeta(depth+1,nodei*2+i,True,values,alpha,beta)
            best=min(value,best)
            beta=min(beta,best)
            if alpha>=beta:
                break
        return best
    
values=[3, 5, 6, 9, 1, 2, 0, -1]
result=alphabeta(0,0,True,values,float('-inf'),float('inf'))
print("Optimal Value:",result)
